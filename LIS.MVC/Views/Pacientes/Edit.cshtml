@model Modelos_LIS.Pacientes

@{
    ViewData["Title"] = "Editar Paciente - LIS";
}

<div class="main-screen">
    <div class="container py-5">
        
        <header class="mb-5 text-center">
            <h1 class="titulo-azul-elegante">Actualizar Información</h1>
            <p class="text-muted fw-bold small-caps">Gestión de Datos del Paciente</p>
        </header>

        <div class="glass-card shadow-lg mx-auto" style="max-width: 800px;">
            <div class="text-center p-4 border-bottom bg-light-blue">
                <div class="icon-circle-blue">
                </div>
                <h3 class="text-primary-dark fw-bold m-0 mt-3">@Model.pac_nombres @Model.pac_apellidos</h3>
                <span class="badge-id">ID de Registro: @Model.Id</span>
            </div>

            <div class="p-5">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="form-group-luxury">
                                <label asp-for="pac_cedula" class="label-premium">Número de Cédula</label>
                                <input asp-for="pac_cedula" class="input-luxury" placeholder="Ej: 100xxxxxxx" />
                                <span asp-validation-for="pac_cedula" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group-luxury">
                                <label asp-for="Paciente_Fecha_Nac" class="label-premium">Fecha de Nacimiento</label>
                                <input asp-for="Paciente_Fecha_Nac" type="date" class="input-luxury" />
                                <span asp-validation-for="Paciente_Fecha_Nac" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group-luxury">
                                <label asp-for="pac_nombres" class="label-premium">Nombres</label>
                                <input asp-for="pac_nombres" class="input-luxury" />
                                <span asp-validation-for="pac_nombres" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group-luxury">
                                <label asp-for="pac_apellidos" class="label-premium">Apellidos</label>
                                <input asp-for="pac_apellidos" class="input-luxury" />
                                <span asp-validation-for="pac_apellidos" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group-luxury">
                                <label asp-for="pac_telefono" class="label-premium">Teléfono / Celular</label>
                                <input asp-for="pac_telefono" class="input-luxury" />
                                <span asp-validation-for="pac_telefono" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group-luxury">
                                <label asp-for="pac_correo" class="label-premium">Correo Electrónico</label>
                                <input asp-for="pac_correo" class="input-luxury" type="email" />
                                <span asp-validation-for="pac_correo" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <hr class="my-5" style="opacity: 0.1;">

                    <div class="d-flex justify-content-center gap-3 mt-4">
                        <a asp-action="Index" class="btn-regresar-minimal text-decoration-none">
                            CANCELAR
                        </a>
                        <button type="submit" class="btn-guardar-luxury">
                            GUARDAR CAMBIOS
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&family=Playfair+Display:wght@700&display=swap');

    .main-screen {
        background: linear-gradient(183deg, rgba(218, 223, 235, 0.93) 15%, rgba(100, 109, 158, 1) 100%);
        font-family: 'Montserrat', sans-serif;
        min-height: 100vh;
        margin-top: -24px;
        background-attachment: fixed;
    }

    .titulo-azul-elegante {
        font-family: 'Playfair Display', serif;
        font-size: 2.8rem;
        color: #1a237e;
        font-weight: 700;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.92);
        backdrop-filter: blur(15px);
        border-radius: 30px;
        border: 1px solid rgba(255, 255, 255, 0.6);
    }

    .icon-circle-blue {
        width: 60px;
        height: 60px;
        background: #1a237e;
        border-radius: 50%;
        margin: 0 auto;
        box-shadow: 0 8px 20px rgba(26, 35, 126, 0.2);
    }

    .badge-id {
        display: inline-block;
        background: #fcf6ba;
        color: #1a237e;
        padding: 4px 15px;
        border-radius: 50px;
        font-weight: 800;
        font-size: 0.7rem;
        margin-top: 10px;
    }

    .form-group-luxury {
        margin-bottom: 5px;
    }

    .label-premium {
        font-size: 0.65rem;
        font-weight: 700;
        color: #64748b;
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-bottom: 8px;
        display: block;
        padding-left: 5px;
    }

    .input-luxury {
        width: 100%;
        padding: 12px 20px;
        border-radius: 15px;
        border: 1.5px solid #e2e8f0;
        background: #f8fafc;
        color: #1e293b;
        font-weight: 600;
        transition: all 0.3s;
    }

        .input-luxury:focus {
            outline: none;
            border-color: #1a237e;
            background: white;
            box-shadow: 0 0 0 4px rgba(26, 35, 126, 0.1);
        }

    .btn-guardar-luxury {
        background: #1a237e;
        color: white;
        padding: 14px 40px;
        border-radius: 50px;
        font-weight: 700;
        border: none;
        font-size: 0.8rem;
        transition: all 0.3s;
    }

        .btn-guardar-luxury:hover {
            background: #0d124d;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(26, 35, 126, 0.3);
        }

    .btn-regresar-minimal {
        background: #64748b;
        color: white;
        padding: 14px 40px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 0.8rem;
    }

    .text-primary-dark {
        color: #1a237e;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}