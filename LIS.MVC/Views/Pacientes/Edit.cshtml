@model Modelos_LIS.Pacientes

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Pacientes</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="form-group">
                <label asp-for="pac_cedula" class="control-label"></label>
                <input asp-for="pac_cedula" class="form-control" />
                <span asp-validation-for="pac_cedula" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="pac_nombres" class="control-label"></label>
                <input asp-for="pac_nombres" class="form-control" />
                <span asp-validation-for="pac_nombres" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="pac_apellidos" class="control-label"></label>
                <input asp-for="pac_apellidos" class="form-control" />
                <span asp-validation-for="pac_apellidos" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Paciente_Fecha_Nac" class="control-label">Fecha de Nacimiento</label>
                <input asp-for="Paciente_Fecha_Nac" type="date" class="form-control" />
                <span asp-validation-for="Paciente_Fecha_Nac" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="pac_telefono" class="control-label"></label>
                <input asp-for="pac_telefono" class="form-control" />
                <span asp-validation-for="pac_telefono" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="pac_correo" class="control-label"></label>
                <input asp-for="pac_correo" class="form-control" />
                <span asp-validation-for="pac_correo" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
