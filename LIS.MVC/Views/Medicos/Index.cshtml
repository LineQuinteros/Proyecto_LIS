@model IEnumerable<Modelos_LIS.Medicos>

@{
    ViewData["Title"] = "Directorio Médico";
}

<div class="main-screen">
    <div class="container py-5">
        
        <header class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h1 class="titulo-dorado-premium">Cuerpo Médico</h1>
                <p class="text-muted fw-bold small-caps ms-2">Directorio de Profesionales Autorizados</p>
            </div>
            <a asp-action="Create" class="btn-luxury">
                <span>+ NUEVO REGISTRO</span>
            </a>
        </header>

        <div class="glass-card shadow-lg">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="py-4 ps-4">ID</th>
                        <th class="py-4">Cédula</th>
                        <th class="py-4">Nombres</th>
                        <th class="py-4">Apellidos</th>
                        <th class="py-4">Contacto</th>
                        <th class="py-4">Especialidad</th>
                        <th class="py-4 text-end pe-5">GESTIÓN</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="luxury-row">
                            <td class="ps-4 align-middle">
                                <span class="id-tag-small">#@item.Id</span>
                            </td>
                            <td class="align-middle">
                                <div class="text-muted small fw-bold">@item.med_cedula</div>
                            </td>
                            <td class="align-middle">
                                <div class="espe-nombre-refined">@item.med_nombres</div>
                            </td>
                            <td class="align-middle">
                                <div class="espe-nombre-refined">@item.med_apellidos</div>
                            </td>
                            <td class="align-middle">
                                <div class="text-dark small">@item.med_telefono</div>
                                <div class="text-muted tiny">@item.med_correo</div>
                            </td>
                            <td class="align-middle">
                                <span class="badge-especialidad">
                                    @item.Especialidad.espe_nombre
                                </span>
                            </td>
                            <td class="text-end pe-4 align-middle">
                                <div class="action-links">
                                    <a href="@Url.Action("Edit", new { id = item.Id })" class="link-edit">Editar</a>
                                    <a href="@Url.Action("Details", new { id = item.Id })" class="link-view">Ver</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* Importación de fuentes */
    @@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&family=Playfair+Display:wght@700&display=swap');

    body {
        background: linear-gradient(183deg, rgba(218, 223, 235, 0.93) 15%, rgba(100, 109, 158, 1) 100%);
        font-family: 'Montserrat', sans-serif;
        min-height: 100vh;
        background-attachment: fixed;
    }

    /* TÍTULO: Champagne Gold */
    .titulo-dorado-premium {
        font-family: 'Playfair Display', serif;
        font-size: 3.8rem;
        font-weight: 700;
        letter-spacing: -1px;
        background: linear-gradient(to right, #bf953f, #fcf6ba, #b38728, #fbf5b7, #aa771c);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin: 0;
        filter: drop-shadow(0px 2px 2px rgba(0,0,0,0.1));
    }

    .small-caps {
        font-size: 0.7rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #1a237e !important;
    }

    /* Tamaños ajustados */
    .id-tag-small {
        color: #b59410;
        font-weight: 700;
        font-size: 0.8rem;
    }

    .espe-nombre-refined {
        font-weight: 700;
        color: #1a237e;
        font-size: 1.05rem; /* Ajustado ligeramente para balance */
    }

    .tiny {
        font-size: 0.7rem;
    }

    /* Estilo para la Especialidad */
    .badge-especialidad {
        font-size: 0.7rem;
        padding: 5px 12px;
        border-radius: 50px;
        background: rgba(26, 35, 126, 0.08);
        color: #1a237e;
        font-weight: 700;
        border: 1px solid rgba(26, 35, 126, 0.1);
        text-transform: uppercase;
    }

    /* Card Glassmorphism */
    .glass-card {
        background: rgba(255, 255, 255, 0.75);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 20px;
        overflow: hidden;
    }

    .luxury-row {
        transition: all 0.3s ease;
        border-left: 5px solid transparent;
    }

        .luxury-row:hover {
            background: rgba(255, 255, 255, 0.9) !important;
            border-left: 5px solid #b59410;
            transform: translateX(5px);
        }

    .table thead th {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        font-weight: 700;
        color: #64748b;
        border-bottom: 1px solid rgba(0,0,0,0.05);
    }

    .action-links a {
        text-decoration: none;
        font-size: 0.75rem;
        font-weight: 700;
        margin-left: 15px;
        text-transform: uppercase;
        transition: all 0.2s;
        padding: 6px 12px;
        border-radius: 4px;
    }

    .link-edit {
        color: #3b82f6;
        border: 1px solid transparent;
    }
    
        .link-edit:hover {
            background: rgba(59, 130, 246, 0.1);
            border-color: #3b82f6;
        }

    .link-view {
        color: #1a237e;
        border: 1px solid transparent;
    }

        .link-view:hover {
            background: rgba(26, 35, 126, 0.1);
            border-color: #1a237e;
        }

    .btn-luxury {
        background: #1a237e;
        color: white;
        text-decoration: none;
        padding: 12px 30px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 0.75rem;
        transition: all 0.3s ease;
    }
</style>