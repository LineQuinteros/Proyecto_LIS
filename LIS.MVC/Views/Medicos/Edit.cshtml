@model Modelos_LIS.Medicos

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Medicos</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="form-group">
                <label asp-for="med_cedula" class="control-label"></label>
                <input asp-for="med_cedula" class="form-control" />
                <span asp-validation-for="med_cedula" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="med_nombres" class="control-label"></label>
                <input asp-for="med_nombres" class="form-control" />
                <span asp-validation-for="med_nombres" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="med_apellidos" class="control-label"></label>
                <input asp-for="med_apellidos" class="form-control" />
                <span asp-validation-for="med_apellidos" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="med_telefono" class="control-label"></label>
                <input asp-for="med_telefono" class="form-control" />
                <span asp-validation-for="med_telefono" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="med_correo" class="control-label"></label>
                <input asp-for="med_correo" class="form-control" />
                <span asp-validation-for="med_correo" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="med_password" class="control-label"></label>
                <input asp-for="med_password" class="form-control" />
                <span asp-validation-for="med_password" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="especialidadId" class="control-label"></label>
                <select asp-for="especialidadId" class="form-control" asp-items="ViewBag.Especialidades">
                    <option value="">-- Seleccione una especialidad --</option>
                </select>
                <span asp-validation-for="especialidadId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
