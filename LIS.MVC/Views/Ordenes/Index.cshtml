@model IEnumerable<Modelos_LIS.Ordenes>

@{
    ViewData["Title"] = "Gestión de Órdenes";
}

<div class="main-screen">
    <div class="container py-5">
        
        <header class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h1 class="titulo-dorado-premium">Órdenes de Laboratorio</h1>
                <p class="text-muted fw-bold small-caps ms-2">Control y Seguimiento de Análisis Clínicos</p>
            </div>
            <a asp-action="Create" class="btn-luxury">
                <span>+ NUEVA ORDEN</span>
            </a>
        </header>

        <div class="glass-card shadow-lg">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="py-4 ps-4">ID</th>
                        <th class="py-4">Fecha de Emisión</th>
                        <th class="py-4 text-center">Estado de Análisis</th>
                        <th class="py-4">Médico Solicitante</th>
                        <th class="py-4">Paciente</th>
                        <th class="py-4 text-end pe-5">GESTIÓN</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="luxury-row">
                            <td class="ps-4 align-middle">
                                <span class="id-tag-small">#@item.Id</span>
                            </td>
                            <td class="align-middle">
                                <div class="text-dark small fw-semibold">@item.orden_fecha.ToShortDateString()</div>
                                <div class="text-muted tiny">Registro oficial</div>
                            </td>
                            <td class="text-center align-middle">
                                @if (item.orden_estado)
                                {
                                    <span class="status-badge-complete">
                                        <i class="bi bi-check-circle-fill"></i> Completado
                                    </span>
                                }
                                else
                                {
                                    <span class="status-badge-pending">
                                        <i class="bi bi-clock-history"></i> Pendiente
                                    </span>
                                }
                            </td>
                            <td class="align-middle">
                                <div class="espe-nombre-refined">@item.Medico.med_nombres @item.Medico.med_apellidos</div>
                            </td>
                            <td class="align-middle">
                                <div class="espe-nombre-refined">@item.Paciente.pac_nombres @item.Paciente.pac_apellidos</div>
                            </td>
                            <td class="text-end pe-4 align-middle">
                                <div class="action-links">
                                    <a href="@Url.Action("Edit", new { id = item.Id })" class="link-edit">Editar</a>
                                    <a href="@Url.Action("Details", new { id = item.Id })" class="link-view">Ver</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&family=Playfair+Display:wght@700&display=swap');

    body {
        background: linear-gradient(183deg, rgba(218, 223, 235, 0.93) 15%, rgba(100, 109, 158, 1) 100%);
        font-family: 'Montserrat', sans-serif;
        min-height: 100vh;
        background-attachment: fixed;
    }

    .titulo-dorado-premium {
        font-family: 'Playfair Display', serif;
        font-size: 3.8rem;
        font-weight: 700;
        letter-spacing: -1px;
        background: linear-gradient(to right, #bf953f, #fcf6ba, #b38728, #fbf5b7, #aa771c);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin: 0;
        filter: drop-shadow(0px 2px 2px rgba(0,0,0,0.1));
    }

    .small-caps {
        font-size: 0.7rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #1a237e !important;
    }

    .status-badge-complete {
        background: rgba(25, 135, 84, 0.1);
        color: #198754;
        padding: 6px 14px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 700;
        border: 1px solid rgba(25, 135, 84, 0.2);
    }

    .status-badge-pending {
        background: rgba(13, 110, 253, 0.1);
        color: #0d6efd;
        padding: 6px 14px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 700;
        border: 1px solid rgba(13, 110, 253, 0.2);
    }

    .id-tag-small {
        color: #b59410;
        font-weight: 700;
        font-size: 0.8rem;
    }

    .espe-nombre-refined {
        font-weight: 700;
        color: #1a237e;
        font-size: 1.05rem;
    }

    .tiny { font-size: 0.65rem; }

    .glass-card {
        background: rgba(255, 255, 255, 0.75);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 20px;
        overflow: hidden;
    }

    .luxury-row {
        transition: all 0.3s ease;
        border-left: 5px solid transparent;
    }

    .luxury-row:hover {
        background: rgba(255, 255, 255, 0.9) !important;
        border-left: 5px solid #b59410;
        transform: translateX(5px);
    }

    .table thead th {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        font-weight: 700;
        color: #64748b;
        border-bottom: 1px solid rgba(0,0,0,0.05);
    }

    .action-links a {
        text-decoration: none;
        font-size: 0.75rem;
        font-weight: 700;
        margin-left: 15px;
        text-transform: uppercase;
        padding: 8px 15px;
        border-radius: 5px;
        transition: all 0.2s;
    }

    .link-edit { color: #3b82f6; }
    .link-edit:hover { background: rgba(59, 130, 246, 0.1); }

    .link-view { color: #1a237e; }
    .link-view:hover { background: rgba(26, 35, 126, 0.1); }

    .btn-luxury {
        background: #1a237e;
        color: white !important;
        text-decoration: none;
        padding: 12px 30px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 0.75rem;
        transition: all 0.3s ease;
    }
</style>