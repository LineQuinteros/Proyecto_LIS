@model Modelos_LIS.Examenes

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css">

@{
    ViewData["Title"] = "Nuevo Examen - LIS";
}

<div class="main-screen">
    <div class="container py-5">
        
        <header class="mb-5 text-center">
            <h1 class="titulo-azul-elegante">Registro de Exámenes</h1>
            <p class="text-muted fw-bold small-caps">Gestión de Parámetros Clínicos</p>
        </header>

        <div class="glass-card shadow-lg p-5 mx-auto" style="max-width: 650px;">
            <div class="text-center mb-4">
                <div class="icon-circle-blue">
                    <i class="bi bi-microscope"></i>
                </div>
                <h3 class="text-primary-dark fw-bold">Nuevo Análisis Clínico</h3>
            </div>

            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="alert-error-luxury mb-4"></div>

                <div class="form-group-luxury mb-4">
                    <label asp-for="exam_nombre" class="label-premium">
                        <i class="bi bi-clipboard2-pulse me-2"></i>NOMBRE DEL EXAMEN
                    </label>
                    <input asp-for="exam_nombre" class="input-luxury" placeholder="Ej: Glucosa en ayunas" />
                    <span asp-validation-for="exam_nombre" class="text-danger small fw-bold"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <div class="form-group-luxury">
                            <label asp-for="exam_unidad" class="label-premium">
                                <i class="bi bi-droplet me-2"></i>UNIDAD (u)
                            </label>
                            <input asp-for="exam_unidad" class="input-luxury" placeholder="Ej: mg/dL" />
                            <span asp-validation-for="exam_unidad" class="text-danger small fw-bold"></span>
                        </div>
                    </div>

                    <div class="col-md-6 mb-4">
                        <div class="form-group-luxury">
                            <label asp-for="exam_referencia" class="label-premium">
                                <i class="bi bi-info-circle me-2"></i>REFERENCIA
                            </label>
                            <input asp-for="exam_referencia" class="input-luxury" placeholder="Ej: 70 - 100" />
                            <span asp-validation-for="exam_referencia" class="text-danger small fw-bold"></span>
                        </div>
                    </div>
                </div>

                <hr class="my-4" style="opacity: 0.1;">

                <div class="d-flex justify-content-center gap-3">
                    <a asp-action="Index" class="btn-regresar-minimal text-decoration-none">CANCELAR</a>
                    <button type="submit" class="btn-guardar-blue">
                        <i class="bi bi-plus-circle me-2"></i>CREAR EXAMEN
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&family=Playfair+Display:wght@700&display=swap');

    .main-screen {
        background: linear-gradient(183deg, rgba(218, 223, 235, 0.93) 15%, rgba(100, 109, 158, 1) 100%);
        font-family: 'Montserrat', sans-serif;
        min-height: 100vh;
        margin-top: -24px;
        background-attachment: fixed;
    }

    .titulo-azul-elegante {
        font-family: 'Playfair Display', serif;
        font-size: 3.5rem;
        color: #1a237e;
        font-weight: 700;
        letter-spacing: -1px;
    }

    .small-caps {
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 0.8rem;
    }

    .text-primary-dark {
        color: #1a237e;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-radius: 25px;
        border: 1px solid rgba(255, 255, 255, 0.5);
    }

    /* ESTILO DEL CÍRCULO Y EL ICONO */
    .icon-circle-blue {
        width: 70px;
        height: 70px;
        background: #1a237e;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        box-shadow: 0 8px 20px rgba(26, 35, 126, 0.2);
    }

        .icon-circle-blue i {
            color: #fcf6ba !important; /* Dorado Champagne */
            font-size: 2.2rem;
            line-height: 1;
            display: block;
        }

    .label-premium {
        font-size: 0.7rem;
        font-weight: 700;
        color: #64748b;
        letter-spacing: 1px;
        margin-bottom: 0.5rem;
        display: block;
        text-transform: uppercase;
    }

        .label-premium i {
            color: #1a237e;
            font-size: 0.9rem;
        }

    .input-luxury {
        width: 100%;
        background: white;
        border: 1px solid #dee2e6;
        border-radius: 12px;
        padding: 12px 15px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
    }

        .input-luxury:focus {
            border-color: #1a237e;
            outline: none;
            box-shadow: 0 0 10px rgba(26, 35, 126, 0.1);
        }

    .btn-guardar-blue {
        background: #1a237e;
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 0.8rem;
        transition: all 0.3s;
        cursor: pointer;
    }

    .btn-regresar-minimal {
        background: #64748b;
        color: white;
        padding: 12px 30px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 0.8rem;
    }

    .btn-guardar-blue:hover {
        background: #0d124d;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(26, 35, 126, 0.3);
    }

    .alert-error-luxury {
        background: #fff5f5;
        color: #c53030;
        padding: 12px;
        border-radius: 10px;
        font-size: 0.85rem;
        border-left: 5px solid #c53030;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}