@model IEnumerable<Modelos_LIS.Examenes>

@{
    ViewData["Title"] = "Index";
}

<div class="container mt-4">
    <h1 class="text-primary fw-bold mb-4">Catálogo de Exámenes</h1>

    <p>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            + Crear Nuevo Examen
        </a>
    </p>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4">@Html.DisplayNameFor(model => model.Id)</th>
                    <th>@Html.DisplayNameFor(model => model.exam_nombre)</th>
                    <th>@Html.DisplayNameFor(model => model.exam_unidad)</th>
                    <th>@Html.DisplayNameFor(model => model.exam_referencia)</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <span class="badge bg-light text-dark border">@Html.DisplayFor(modelItem => item.Id)</span>
                        </td>
                        <td class="fw-bold">
                            @Html.DisplayFor(modelItem => item.exam_nombre)
                        </td>
                        <td class="text-primary">
                            @Html.DisplayFor(modelItem => item.exam_unidad)
                        </td>
                        <td class="text-muted small">
                            @Html.DisplayFor(modelItem => item.exam_referencia)
                        </td>
                        <td class="text-center">
                            <div class="btn-group">
                                <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-sm btn-outline-primary">Editar</a>
                                <a href="@Url.Action("Details", new { id = item.Id })" class="btn btn-sm btn-outline-secondary">Ver</a>
                                <a href="@Url.Action("Delete", new { id = item.Id })" class="btn btn-sm btn-outline-danger">Borrar</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    
    .table thead th {
        font-size: 0.85rem;
        text-transform: uppercase;
        padding: 15px;
    }
</style>