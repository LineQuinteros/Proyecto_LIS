@model IEnumerable<Modelos_LIS.Examenes>

@{
    ViewData["Title"] = "Catálogo de Exámenes";
}

<div class="container mt-4">
    <div class="row mb-4 align-items-center bg-white p-3 shadow-sm rounded-3 border-start border-primary border-5">
        <div class="col-md-8">
            <h2 class="text-primary fw-bold mb-0">
                <i class="bi bi-microscope me-2"></i>Gestión de Exámenes
            </h2>
            <p class="text-muted mb-0 small">Catálogo oficial de análisis para el laboratorio clínico.</p>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow">
                <i class="bi bi-plus-circle me-1"></i> Nuevo Examen
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr class="text-secondary">
                            <th class="ps-4 py-3">ID</th>
                            <th class="py-3">Nombre del Examen</th>
                            <th class="py-3">Unidad</th>
                            <th class="py-3">Referencia</th>
                            <th class="text-center py-3">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="badge bg-light text-dark border">#@item.Id</span>
                                </td>
                                <td>
                                    <div class="fw-bold text-dark">@item.exam_nombre</div>
                                </td>
                                <td>
                                    <span class="text-primary fw-semibold">@item.exam_unidad</span>
                                </td>
                                <td>
                                    <small class="text-muted italic">@item.exam_referencia</small>
                                </td>
                                <td class="text-center pe-4">
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Ver Detalles">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Eliminar">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@* --- Estilos CSS específicos para esta tabla --- *@
<style>
    .table thead th {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 700;
        border-bottom: 2px solid #f8f9fa;
    }

    .table tbody tr {
        transition: all 0.2s ease;
    }

    .table tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.03) !important;
        transform: scale(1.002);
    }

    .btn-group .btn {
        padding: 0.4rem 0.8rem;
    }

    /* Ajuste para que los iconos de Bootstrap se vean bien */
    @@import url("https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css");
</style>