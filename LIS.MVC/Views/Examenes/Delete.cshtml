@model Modelos_LIS.Examenes

@{
    ViewData["Title"] = "Eliminar Examen - LIS";
}

<div class="main-screen">
    <div class="container py-5">
        
        <header class="mb-5 text-center">
            <h1 class="titulo-rojo-elegante">Confirmar Eliminación</h1>
            <p class="text-muted fw-bold small-caps">Esta acción es irreversible en el catálogo de análisis</p>
        </header>

        <div class="glass-card shadow-lg mx-auto" style="max-width: 700px;">
            
            <div class="text-center p-4 border-bottom bg-light-danger">
                <div class="icon-circle-danger">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
                <h3 class="text-danger-dark fw-bold m-0 mt-3">¿Desea eliminar este examen?</h3>
                <span class="badge-warning-custom">PROCEDER CON PRECAUCIÓN</span>
            </div>

            <div class="p-5">
                <div class="info-card-preview mb-5">
                    <div class="row g-4">
                        <div class="col-12 border-bottom pb-3">
                            <label class="label-premium">Nombre del Examen</label>
                            <p class="value-text-big">@Model.exam_nombre</p>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="label-premium">Unidad de Medida</label>
                            <p class="value-text">@(string.IsNullOrEmpty(Model.exam_unidad) ? "N/A" : Model.exam_unidad)</p>
                        </div>

                        <div class="col-md-6">
                            <label class="label-premium">Rango de Referencia</label>
                            <p class="value-text">@Model.exam_referencia</p>
                        </div>

                        <div class="col-12">
                            <label class="label-premium">Identificador del Sistema</label>
                            <p class="text-muted small fw-bold">ID Registro: #@Model.Id</p>
                        </div>
                    </div>
                </div>

                <form asp-action="Delete">
                    <div class="d-flex justify-content-center gap-3">
                        <a asp-action="Index" class="btn-regresar-minimal text-decoration-none">
                            CANCELAR Y VOLVER
                        </a>
                        <button type="submit" class="btn-delete-luxury">
                            CONFIRMAR ELIMINACIÓN
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&family=Playfair+Display:wght@700&display=swap');

    .main-screen {
        background: linear-gradient(183deg, rgba(218, 223, 235, 0.93) 15%, rgba(100, 109, 158, 1) 100%);
        font-family: 'Montserrat', sans-serif;
        min-height: 100vh;
        background-attachment: fixed;
    }

    .titulo-rojo-elegante {
        font-family: 'Playfair Display', serif;
        font-size: 2.8rem;
        color: #991b1b;
        font-weight: 700;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(15px);
        border-radius: 30px;
        border: 1px solid rgba(239, 68, 68, 0.2);
        overflow: hidden;
    }

    .icon-circle-danger {
        width: 60px;
        height: 60px;
        background: #ef4444;
        border-radius: 50%;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.5rem;
        box-shadow: 0 8px 20px rgba(239, 68, 68, 0.2);
    }

    .info-card-preview {
        background: #fff5f5;
        padding: 30px;
        border-radius: 20px;
        border: 1px solid #fee2e2;
    }

    .label-premium {
        font-size: 0.65rem;
        font-weight: 700;
        color: #94a3b8;
        letter-spacing: 1px;
        text-transform: uppercase;
        display: block;
        margin-bottom: 5px;
    }

    .value-text-big {
        font-size: 1.6rem;
        font-weight: 700;
        color: #1e293b;
        margin: 0;
    }

    .value-text {
        font-size: 1.1rem;
        font-weight: 600;
        color: #475569;
        margin: 0;
    }

    .btn-delete-luxury {
        background: #ef4444;
        color: white;
        padding: 14px 35px;
        border-radius: 50px;
        font-weight: 700;
        border: none;
        font-size: 0.8rem;
        transition: all 0.3s ease;
    }

        .btn-delete-luxury:hover {
            background: #dc2626;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(220, 38, 38, 0.3);
        }

    .btn-regresar-minimal {
        background: #64748b;
        color: white !important;
        padding: 14px 35px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 0.8rem;
    }

    .badge-warning-custom {
        display: inline-block;
        background: #fef2f2;
        color: #b91c1c;
        padding: 4px 15px;
        border-radius: 50px;
        font-weight: 800;
        font-size: 0.7rem;
        border: 1px solid #fee2e2;
        margin-top: 10px;
    }
</style>