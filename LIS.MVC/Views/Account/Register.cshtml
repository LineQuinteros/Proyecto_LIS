@{
    ViewData["Title"] = "Registro de Usuario - LIS";
}

<div class="login-full-wrapper">
    <div class="login-background">
        <div class="container d-flex align-items-center justify-content-center min-vh-100">
            
            <div class="col-md-8 col-lg-6 col-xl-5 py-5">
                <div class="glass-login-card shadow-2xl">
                    
                    <div class="login-header-premium">
                        <p class="subtitle-luxury">NUEVA CUENTA</p>
                        <div class="icon-circle-gold">
                            <i class="bi bi-person-plus-fill"></i>
                        </div>
                        <h2 class="titulo-dorado-login">Registro</h2>
                        <p class="text-white-50 small mt-2">Cree sus credenciales de acceso al sistema</p>
                    </div>

                    <div class="login-body-refined">
                        <form asp-action="Register" asp-controller="Account" method="post">
                            
                            <div class="row">
                                <div class="col-md-12 mb-4">
                                    <div class="form-group-luxury">
                                        <label class="label-premium">
                                            <i class="bi bi-person me-2"></i>NOMBRE COMPLETO
                                        </label>
                                        <input type="text" name="nombre" class="input-luxury"
                                               required placeholder="Ej: Juan Pérez">
                                    </div>
                                </div>

                                <div class="col-md-12 mb-4">
                                    <div class="form-group-luxury">
                                        <label class="label-premium">
                                            <i class="bi bi-envelope-at me-2"></i>CORREO ELECTRÓNICO
                                        </label>
                                        <input type="email" name="email" class="input-luxury"
                                               required placeholder="usuario@laboratorio.com">
                                    </div>
                                </div>

                                <div class="col-md-6 mb-4">
                                    <div class="form-group-luxury">
                                        <label class="label-premium">
                                            <i class="bi bi-key me-2"></i>CONTRASEÑA
                                        </label>
                                        <input type="password" name="password" class="input-luxury"
                                               required placeholder="••••••••">
                                    </div>
                                </div>

                                <div class="col-md-6 mb-5">
                                    <div class="form-group-luxury">
                                        <label class="label-premium">
                                            <i class="bi bi-shield-check me-2"></i>CONFIRMAR
                                        </label>
                                        <input type="password" name="confirmPassword" class="input-luxury"
                                               required placeholder="••••••••">
                                    </div>
                                </div>
                            </div>

                            <button type="submit" class="btn-login-gold w-100">
                                <span class="btn-text">CREAR MI CUENTA</span>
                                <i class="bi bi-check2-circle ms-2"></i>
                            </button>

                            @if (ViewBag.ErrorMessage != null)
                            {
                                <div class="alert-error-luxury mt-4">
                                    <i class="bi bi-exclamation-circle me-2"></i>@ViewBag.ErrorMessage
                                </div>
                            }
                        </form>
                    </div>

                    <div class="login-footer-minimal">
                        <span class="text-white-50 small">¿Ya tiene una cuenta activa?</span>
                        <a asp-action="Login" asp-controller="Account" class="link-gold-refined">
                            INICIAR SESIÓN
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&family=Playfair+Display:wght@700&display=swap');

    /* 1. ELIMINAR LADOS BLANCOS */
    .login-full-wrapper {
        margin-left: calc(-50vw + 50%);
        margin-right: calc(-50vw + 50%);
        width: 100vw;
        position: relative;
        overflow: hidden;
    }

    .login-background {
        background: linear-gradient(rgba(10, 23, 58, 0.8), rgba(26, 35, 126, 0.9)), url('@Url.Content("~/images/fondo-lab.jpg")');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        min-height: 100vh;
        margin-top: -24px;
    }

    /* 2. TARJETA GLASSMORPISM */
    .glass-login-card {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 30px;
        overflow: hidden;
    }

    .login-header-premium {
        padding: 2.5rem 2rem 1rem;
        text-align: center;
    }

    .subtitle-luxury {
        font-family: 'Montserrat', sans-serif;
        color: #b59410;
        font-weight: 700;
        letter-spacing: 4px;
        font-size: 0.65rem;
        margin-bottom: 1rem;
    }

    .icon-circle-gold {
        width: 60px;
        height: 60px;
        background: linear-gradient(45deg, #bf953f, #fcf6ba);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
        font-size: 1.5rem;
        color: #1a237e;
        box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    }

    .titulo-dorado-login {
        font-family: 'Playfair Display', serif;
        font-size: 2.5rem;
        background: linear-gradient(to right, #bf953f, #fcf6ba, #aa771c);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin: 0;
    }

    /* 3. FORMULARIO REFINADO */
    .login-body-refined {
        padding: 1.5rem 2.5rem 2.5rem;
    }

    .label-premium {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.65rem;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.8);
        letter-spacing: 1.5px;
        margin-bottom: 0.6rem;
        display: block;
    }

    .input-luxury {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 12px;
        padding: 10px 15px;
        color: white;
        width: 100%;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.9rem;
        transition: all 0.3s;
    }

        .input-luxury:focus {
            background: rgba(255, 255, 255, 0.1);
            border-color: #fcf6ba;
            outline: none;
            box-shadow: 0 0 15px rgba(181, 148, 16, 0.3);
        }

    /* 4. BOTÓN DE ORO */
    .btn-login-gold {
        background: linear-gradient(45deg, #bf953f, #fcf6ba, #b38728);
        border: none;
        padding: 14px;
        border-radius: 50px;
        font-family: 'Montserrat', sans-serif;
        font-weight: 700;
        color: #1a237e;
        letter-spacing: 1px;
        transition: all 0.3s;
        box-shadow: 0 10px 25px rgba(0,0,0,0.3);
        font-size: 0.85rem;
    }

        .btn-login-gold:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.4);
            filter: brightness(1.1);
        }

    .alert-error-luxury {
        background: rgba(239, 68, 68, 0.2);
        border: 1px solid #ef4444;
        color: #ff9999;
        padding: 10px;
        border-radius: 10px;
        font-size: 0.8rem;
        text-align: center;
    }

    .login-footer-minimal {
        padding: 1.5rem;
        background: rgba(0,0,0,0.2);
        text-align: center;
    }

    .link-gold-refined {
        color: #fcf6ba;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.75rem;
        margin-left: 10px;
        transition: color 0.3s;
    }

        .link-gold-refined:hover {
            color: #bf953f;
        }

    body {
        overflow-x: hidden;
    }
</style>