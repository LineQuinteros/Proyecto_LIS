@model Modelos_LIS.Resultados

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Resultados</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
         
            <div class="form-group">
                <label asp-for="res_valor" class="control-label"></label>
                <input asp-for="res_valor" class="form-control" />
                <span asp-validation-for="res_valor" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="res_comentario" class="control-label"></label>
                <input asp-for="res_comentario" class="form-control" />
                <span asp-validation-for="res_comentario" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="OrdenId" class="control-label"></label>
                <select asp-for="OrdenId" class="form-control" asp-items="ViewBag.Ordenes">
                    <option value="">-- Seleccione una Orden --</option>
                </select>
                <span asp-validation-for="OrdenId" class="text-danger"></span>

            </div>
            <div class="form-group">
                <label asp-for="ExamenId" class="control-label"></label>
                <select asp-for="ExamenId" class="form-control" asp-items="ViewBag.Examenes">
                    <option value="">-- Seleccione un Examen --</option>
                </select>
                <span asp-validation-for="ExamenId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
