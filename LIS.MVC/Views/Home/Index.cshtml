@{
    ViewData["Title"] = "Inicio - LIS";
}

<div class="row min-vh-100 align-items-center shadow-lg"
     style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)),
    url('@Url.Content("~/images/fondo-lab.jpg")');
    background-size: cover;
    background-position: center;
    margin-top: -24px; /* Esto es para pegar la imagen al menú de arriba */
    border-radius: 0 0 50px 50px;">
    <div class="col-12 text-center text-white p-5">
        
        
        
        <h1 class="display-2 fw-bold mb-4" style="letter-spacing: 2px;">
             <span class="text-info">Laboratory Information System</span>
        </h1>
        
        <p class="fs-3 fw-light mb-5 mx-auto" style="max-width: 800px;">
            Gestión de Laboratorio Clínico.
            
        </p>

        <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
            @if (!User.Identity.IsAuthenticated)
            {
                <a asp-controller="Account" asp-action="Index"
                       class="btn btn-info btn-lg px-5 py-3 fw-bold rounded-pill shadow">
                    INGRESAR AL SISTEMA
                </a>
            }
            else
            {
                <a asp-controller="Ordenes" asp-action="Index"
                       class="btn btn-info btn-lg px-5 py-3 fw-bold rounded-pill shadow">
                    ÓRDENES
                </a>
                <a asp-controller="Pacientes" asp-action="Index"
                       class="btn btn-outline-light btn-lg px-5 py-3 fw-bold rounded-pill">
                    PACIENTES
                </a>
            }
        </div>
    </div>
</div>

