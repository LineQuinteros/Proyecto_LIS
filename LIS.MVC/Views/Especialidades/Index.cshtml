@model IEnumerable<Modelos_LIS.Especialidades>

@{
    ViewData["Title"] = "Especialidades Médicas";
}

<div class="main-screen">
    <div class="container py-5">
        
        <header class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h1 class="titulo-dorado-premium">Especialidades Médicas</h1>
            </div>
            <a asp-action="Create" class="btn-luxury">
                <span>+ NUEVO REGISTRO</span>
            </a>
        </header>

        <div class="glass-card shadow-lg">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="py-4 ps-4">@Html.DisplayNameFor(model => model.Id)</th>
                        <th class="py-4">@Html.DisplayNameFor(model => model.espe_nombre)</th>
                        <th class="py-4">@Html.DisplayNameFor(model => model.espe_descripcion)</th>
                        <th class="py-4 text-end pe-4">GESTIÓN</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="luxury-row">
                            <td class="ps-4">
                                <span class="id-tag-small">#@item.Id</span>
                            </td>
                            <td>
                                <div class="espe-nombre-refined">@item.espe_nombre</div>
                            </td>
                            <td>
                                <div class="text-muted small text-truncate" style="max-width: 300px;">
                                    @item.espe_descripcion
                                </div>
                            </td>
                            <td class="text-end pe-4">
                                <div class="action-links">
                                    <a href="@Url.Action("Edit", new { id = item.Id })" class="link-edit">Editar</a>
                                    <a href="@Url.Action("Details", new { id = item.Id })" class="link-view">Ver</a>
                                    <a href="@Url.Action("Delete", new { id = item.Id })" class="link-delete">Borrar</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&family=Playfair+Display:wght@700&display=swap');

    body {
        background: linear-gradient(183deg, rgba(218, 223, 235, 0.93) 15%, rgba(100, 109, 158, 1) 100%);
        font-family: 'Montserrat', sans-serif;
        min-height: 100vh;
        background-attachment: fixed;
    }

    /* NUEVO DORADO: Champagne Gold con más brillo */
    .titulo-dorado-premium {
        font-family: 'Playfair Display', serif;
        font-size: 3.8rem;
        font-weight: 700;
        letter-spacing: -1px;
        background: linear-gradient(to right, #bf953f, #fcf6ba, #b38728, #fbf5b7, #aa771c);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin: 0;
        filter: drop-shadow(0px 2px 2px rgba(0,0,0,0.1));
    }

    /* Ajuste de tamaño solicitado: Un punto menos de tamaño */
    .id-tag-small {
        color: #b59410;
        font-weight: 700;
        font-size: 0.8rem; /* Más pequeño */
    }

    .espe-nombre-refined {
        font-weight: 700;
        color: #1a237e;
        font-size: 1.1rem; /* Reducido de fs-5 (1.25rem) a 1.1rem */
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.75);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 20px;
        overflow: hidden;
    }

    .luxury-row {
        transition: all 0.3s ease;
        border-left: 5px solid transparent;
    }

    .luxury-row:hover {
        background: rgba(255, 255, 255, 0.9) !important;
        border-left: 5px solid #b59410;
        transform: translateX(5px);
    }

    .table thead th {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 700;
        color: #64748b;
    }

    .action-links a {
        text-decoration: none;
        font-size: 0.8rem;
        font-weight: 600;
        margin-left: 15px;
        text-transform: uppercase;
    }

    .link-edit { color: #3b82f6; }
    .link-view { color: #64748b; }
    .link-delete { color: #ef4444; }

    .btn-luxury {
        background: #1a237e;
        color: white;
        text-decoration: none;
        padding: 12px 30px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 0.75rem;
    }
</style>